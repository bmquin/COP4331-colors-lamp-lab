{
  "devDependencies": {
    "eslint": "^10.2.0",
    "htmlhint": "^1.9.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0"
  },

  "scripts": {
    "lint:js":   "eslint \"**/*.js\" --ignore-pattern node_modules/",
    "lint:css":  "stylelint \"**/*.css\"",
    "lint:html": "htmlhint \"**/*.html\""
  }
}


